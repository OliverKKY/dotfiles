{
  "layer": "bottom",
  "position": "bottom",
  "output": ["DP-4"],
  "height": 180,
  "exclusive": false,
  "passthrough": true,
  "fixed-center": true,
  "reload_style_on_change": true,

  "modules-center": ["custom/splash"],

  "custom/splash": {
    "format": "{}",
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/splash.sh",
    "interval": "once",
    "tooltip": false,
  },
}
