#!/usr/bin/env sh

set -eu

if [ "$#" -lt 1 ]; then
    echo "usage: apply-wal <image>" >&2
    exit 1
fi

image_path=$1
wal_bin=${WAL_BIN:-"$HOME/.local/bin/wal"}

if [ ! -x "$wal_bin" ]; then
    wal_bin=$(command -v wal 2>/dev/null || true)
fi

if [ -z "${wal_bin:-}" ] || [ ! -x "$wal_bin" ]; then
    exit 1
fi

"$wal_bin" -i "$image_path" -n
hyprctl reload >/dev/null 2>&1 || true

if pgrep -x waybar >/dev/null 2>&1; then
    pkill -SIGUSR2 waybar || true
fi

kitty @ --to unix:/tmp/kitty-theme load-config /home/oliver/.config/kitty/kitty.conf >/dev/null 2>&1 || true
